{
  "info": {
    "name": "Ecommerce JPA API Full",
    "description": "Colección completa de pruebas para la API de Ecommerce JPA, incluyendo CRUD de productos, búsqueda avanzada, y endpoints de carrito.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Crear Producto",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Pelota interactiva\",\n  \"descrip\": \"Pelota con luz y movimiento\",\n  \"image_url\": \"https://img.com/pelota.jpg\",\n  \"sku\": \"SKU001\",\n  \"price\": 9.99,\n  \"units\": 100,\n  \"category\": { \"id\": 1 }\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/productos",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "productos"]
        }
      }
    },
    {
      "name": "Listar Productos",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/productos",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "productos"]
        }
      }
    },
    {
      "name": "Obtener Producto por ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/productos/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "productos", "1"]
        }
      }
    },
    {
      "name": "Actualizar Producto",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Pelota interactiva actualizada\",\n  \"descrip\": \"Pelota con luz y sonido\",\n  \"image_url\": \"https://img.com/pelota_new.jpg\",\n  \"sku\": \"SKU001\",\n  \"price\": 12.99,\n  \"units\": 80,\n  \"category\": { \"id\": 1 }\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/productos/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "productos", "1"]
        }
      }
    },
    {
      "name": "Eliminar Producto",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8080/api/productos/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "productos", "1"]
        }
      }
    },
    {
      "name": "Buscar Productos (Filtros, Paginación, Orden)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/productos/search?name=Pelota&categoryId=1&sku=SKU001&page=0&size=5&sortBy=price&direction=desc",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "productos", "search"],
          "query": [
            { "key": "name", "value": "Pelota" },
            { "key": "categoryId", "value": "1" },
            { "key": "sku", "value": "SKU001" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "5" },
            { "key": "sortBy", "value": "price" },
            { "key": "direction", "value": "desc" }
          ]
        }
      }
    },
    {
      "name": "Añadir Producto al Carrito",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8080/api/carrito/add?userId=1&productId=1&quantity=2",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "carrito", "add"],
          "query": [
            { "key": "userId", "value": "1" },
            { "key": "productId", "value": "1" },
            { "key": "quantity", "value": "2" }
          ]
        }
      }
    },
    {
      "name": "Resumen del Carrito",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/carrito/resumen?userId=1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "carrito", "resumen"],
          "query": [
            { "key": "userId", "value": "1" }
          ]
        }
      }
    }
  ]
}

