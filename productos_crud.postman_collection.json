        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Pelota interactiva\",\n  \"descrip\": \"Pelota con luz y movimiento\",\n  \"image_url\": \"https://img.com/pelota.jpg\",\n  \"sku\": \"SKU001\",\n  \"price\": 9.99,\n  \"units\": 100,\n  \"category\": { \"id\": 1 }\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/productos",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "productos"]
        }
      }
    },
