{
  "info": {
    "_postman_id": "ecommerce-jpa-product-crud-2026-02-04",
    "name": "Ecommerce JPA - CRUD Producto",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección de pruebas CRUD para el endpoint /api/productos"
  },
  "item": [
    {
      "name": "Listar todos los productos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}",
          "host": ["{{baseUrl}}"]
        }
      },
      "response": []
    },
    {
      "name": "Crear producto",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Producto Test\",\n  \"descrip\": \"Descripción de prueba\",\n  \"sku\": \"SKU_TEST_001\",\n  \"price\": 99.99,\n  \"units\": 10,\n  \"category\": { \"id\": {{categoryId}} }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}",
          "host": ["{{baseUrl}}"]
        }
      },
      "response": []
    },
    {
      "name": "Obtener producto por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["{{productId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Actualizar producto",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Producto Actualizado\",\n  \"descrip\": \"Descripción actualizada\",\n  \"sku\": \"SKU_TEST_001\",\n  \"price\": 120.50,\n  \"units\": 5,\n  \"category\": { \"id\": {{categoryId}} }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["{{productId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Eliminar producto",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["{{productId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Añadir producto al carrito",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/add-to-cart?userId={{userId}}&productId={{productId}}&quantity=2",
          "host": ["{{baseUrl}}"],
          "path": ["add-to-cart"],
          "query": [
            { "key": "userId", "value": "{{userId}}" },
            { "key": "productId", "value": "{{productId}}" },
            { "key": "quantity", "value": "2" }
          ]
        }
      },
      "response": []
    }
  ]
}
